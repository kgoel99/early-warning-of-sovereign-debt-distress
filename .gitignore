# Raw archives are too large to commit — they live outside the repo.
# See data/README.md for download links.
data/raw/*
!data/raw/.gitkeep

# Model artifacts (binary, regenerable)
*.pt
*.pth
*.ckpt
*.bin
*.onnx
*.h5
*.hdf5

# Other large binary blobs
*.zip
*.tar
*.tar.gz
*.tgz

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# Virtualenvs
.venv/
venv/
env/
.env
.env.local

# OS junk
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
